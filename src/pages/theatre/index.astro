---
import Layout from '../../layouts/Layout.astro';
import TheatreHero from '../../components/theatre/TheatreHero.astro';
import PlaybillGrid from '../../components/theatre/PlaybillGrid.astro';
---

<Layout title="Театр Эмоцика | Спектакли и Билеты" description="Репертуарный детский театр в Гранд Каньоне. Афиша спектаклей, купить билеты." theme="theatre">
    <main class="theatre-page">
        <!-- Brand Header (Velvet Curtain) -->
        <TheatreHero />
        
        <!-- Afisha / Playbill -->
        <div class="container">
             <PlaybillGrid />
        </div>
        
        <div class="theatre-page__footer">
            <p>Мы играем на сцене территории развития "Гранд Каньон".</p>
            <strong>СПб, пр. Энгельса 154</strong>
        </div>
    </main>
</Layout>
