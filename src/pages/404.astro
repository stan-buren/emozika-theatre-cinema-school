---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Страница не найдена — Театр «Эмоцика»">
  <main id="main-content">
    <section class="section section-error">
      <div class="container error-content">
        <div class="error-code">404</div>
        <h1 class="error-title">Сцена не найдена</h1>
        <p class="error-text">
          Похоже, вы зашли слишком далеко за кулисы.
          Этой страницы не существует или она переехала.
        </p>
        <div class="error-actions">
          <a href={import.meta.env.BASE_URL} class="btn btn-primary">На главную</a>
          <a href={`${import.meta.env.BASE_URL}afisha`} class="btn btn-outline">В афишу</a>
        </div>
      </div>
    </section>
  </main>
</Layout>
