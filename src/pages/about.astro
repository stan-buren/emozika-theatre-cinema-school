---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PeopleSection from '../components/PeopleSection.astro';
import AwardsStrip from '../components/AwardsStrip.astro';
import FestivalsList from '../components/FestivalsList.astro';
import ReviewsGrid from '../components/ReviewsGrid.astro';
import BranchesGrid from '../components/BranchesGrid.astro';
import FaqList from '../components/FaqList.astro';
import galleryData from '../data/gallery.json';
import reviewsData from '../data/reviews.json';
import faqData from '../data/faq.json';
import branchesData from '../data/branches.json';
import awardsData from '../data/awards.json';
import statsData from '../data/stats.json';
import { getTopAwards, getSortedFestivals } from '../utils/awards-helpers.js';

const topAwards = getTopAwards(awardsData);
const sortedFestivals = getSortedFestivals(awardsData);


// --- Logic for Awards ---



const branches = branchesData.branches || [];
const sortedBranches = [...branches].sort((a, b) => {
    // 1. Сначала площадки с группами 18+
    if (a.isAdults && !b.isAdults) return -1;
    if (!a.isAdults && b.isAdults) return 1;

    // 2. Потом по станции метро (по алфавиту)
    var metroA = (a.metro || "").toLowerCase();
    var metroB = (b.metro || "").toLowerCase();
    if (metroA < metroB) return -1;
    if (metroA > metroB) return 1;

    // 3. Город (на всякий случай)
    var cityA = (a.city || "").toLowerCase();
    var cityB = (b.city || "").toLowerCase();
    if (cityA < cityB) return -1;
    if (cityA > cityB) return 1;

    // 4. Название площадки
    var placeA = (a.place || "").toLowerCase();
    var placeB = (b.place || "").toLowerCase();
    if (placeA < placeB) return -1;
    if (placeA > placeB) return 1;

    return 0;
});


---

<Layout title="О театре и команде | Театр «Эмоцика»" description="История театра «Эмоцика», наша команда педагогов и режиссеров, отзывы родителей, фотогалерея и документы.">
  <main id="main-content">
    <section class="section section-page-header">
      <div class="container">
        <h1 class="page-title">О театре</h1>
      </div>
    </section>
    <section id="people" class="section section-people section-card reveal-on-scroll">
      <div class="section-inner">
        <div class="container">
          <header class="section-header">
            <h2 class="section-title section-title--handdrawn">Люди театра</h2>
            <p class="section-subtitle">За спектаклями и занятиями в «Эмоцике» стоят режиссёры, педагоги, актёры и юные
              артисты студии. Здесь только часть нашей команды и звёзд студии.</p>
            <div class="section-chips">
              <span class="chip">Режиссёры</span>
              <span class="chip">Педагоги</span>
              <span class="chip">Юные артисты</span>
            </div>
          </header>
          <div class="people-shell">
            <div class="people-filters" data-people-filters role="tablist" aria-label="Группы людей театра"></div>
            <div class="people-layout" data-people-root></div>
          </div>
        </div>
      </div>
    </section>

    <!--
    ========================================================================
    Блок кастинга в фильмы КиноШколы «Эмоция»
    ========================================================================
    -->
    <section id="stats" class="section section-facts reveal-on-scroll">
      <div class="container">
        <h2 class="section-title">Цифры и факты</h2>
        <p class="section-subtitle">
          За 12 лет студия «Эмоция» и театр «Эмоцика» выросли из маленькой студии в большую творческую семью.
          Несколько цифр, которые помогают понять масштаб.
        </p>
        <div class="section-chips">
          <span class="chip">12 лет опыта</span>
          <span class="chip">15 филиалов</span>
          <span class="chip">400+ детей</span>
        </div>

        <div class="facts-grid">
          {statsData.map(stat => (
            <article class="fact-card">
              <h3 class="fact-number stat-number" data-target={stat.number} data-suffix={stat.suffix}>{stat.label}</h3>
              <p class="fact-label">{stat.sublabel}</p>
              <p class="fact-text">{stat.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>


    <section id="awards" class="section section-awards reveal-on-scroll">
      <div class="container">
        <div class="section-header">
          <!-- <p class="eyebrow eyebrow--dark">Часть фестивального пути</p> -->
          <h2 class="section-title">Награды и фестивали</h2>
          <p class="section-subtitle">Спектакли и фильмы «Эмоцики» регулярно получают гран-при и призы на российских
            и международных конкурсах.</p>
          <div class="section-chips">
            <span class="chip chip--glass">Гран-при</span>
            <span class="chip chip--glass">Дипломы жюри</span>
            <span class="chip chip--glass">Россия + мир</span>
          </div>
        </div>
        <div class="awards-strip-shell">
          <AwardsStrip awards={topAwards} />
        </div>

        <FestivalsList festivals={sortedFestivals} />
      </div>
    </section>


    <!--
    ========================================================================
    Блок отзывов
    ========================================================================
    -->
    <section id="reviews" class="section section-reviews reveal-on-scroll">
      <div class="container">
        <div class="section-header section-header--center">
          <p class="eyebrow">Отзывы</p>
          <h2 class="section-title">Видеоистории родителей</h2>
          <p class="section-subtitle">
            Живые впечатления мам, пап и детей после занятий и спектаклей «Эмоции».
          </p>
          <div class="section-chips">
            <span class="chip">Эмоции детей</span>
            <span class="chip">Отзывы родителей</span>
            <span class="chip">Видео 1–2 минуты</span>
          </div>
        </div>

        <div class="reviews-strip-shell">
          <button class="reviews-strip__arrow reviews-strip__arrow--left" type="button" aria-label="Предыдущий отзыв"
            data-reviews-arrow="left">
            ‹
          </button>

          <ReviewsGrid reviews={reviewsData} />

          <button class="reviews-strip__arrow reviews-strip__arrow--right" type="button" aria-label="Следующий отзыв"
            data-reviews-arrow="right">
            ›
          </button>
        </div>

        <p class="reviews-hint">
          Листайте ленту вправо, чтобы посмотреть другие истории.
        </p>
      </div>

      <!-- Лайтбокс для просмотра выбранного видеоотзыва -->
      <div class="review-lightbox" data-review-lightbox aria-hidden="true" hidden>
        <div class="review-lightbox__backdrop" data-review-lightbox-backdrop></div>

        <div class="review-lightbox__dialog" role="dialog" aria-modal="true" aria-labelledby="review-lightbox-title">
          <button class="review-lightbox__close" type="button" aria-label="Закрыть отзыв" data-review-lightbox-close>
            ✕
          </button>

          <div class="review-lightbox__video">
            <!-- Видеоплеер подставляется через JavaScript -->
          </div>

          <div class="review-lightbox__body">
            <h3 class="review-lightbox__title" id="review-lightbox-title"></h3>
            <p class="review-lightbox__quote"></p>
            <p class="review-lightbox__meta"></p>
          </div>
        </div>
      </div>
    </section>

    <!--
    ========================================================================
    Блок галереи
    ========================================================================
    -->
    <section id="gallery" class="section section-gallery">
      <div class="container">
        <header class="section-header">
          <h2 class="section-title section__title">Галерея</h2>
          <p class="section-subtitle section__subtitle">
            Несколько кадров с наших репетиций, спектаклей и закулисья.
          </p>
          <div class="section-chips">
            <span class="chip chip--glass">Сцена</span>
            <span class="chip chip--glass">Репетиции</span>
            <span class="chip chip--glass">Закулисье</span>
          </div>
        </header>

        <div class="gallery">
          <div class="gallery__header">
            <div class="gallery__tabs" aria-label="Фильтр фотографий">
              <button class="gallery-tab is-active" type="button" data-gallery-filter="all">
                Все
              </button>
              <button class="gallery-tab" type="button" data-gallery-filter="stage">
                Сцена
              </button>
              <button class="gallery-tab" type="button" data-gallery-filter="rehearsal">
                Репетиции
              </button>
              <button class="gallery-tab" type="button" data-gallery-filter="backstage">
                Закулисье
              </button>
            </div>

            <PeopleSection class="reveal-on-scroll" />

            <p class="gallery__hint">
              Листайте ленту в сторону — как киноплёнку, там больше кадров.
            </p>
          </div>

          <div class="gallery__scroller-wrapper">
            <div class="gallery__scroller" data-gallery-scroller aria-label="Фотогалерея театра">
              {galleryData.map((item, index) => (
                <button type="button" class="gallery-card" data-gallery-id={item.id} data-gallery-index={index} data-category={item.category}>
                  <div class="gallery-card__image-wrapper">
                    <img src={item.src} alt={item.alt} class="gallery-card__image" loading="lazy" />
                    <div class="gallery-card__frame"></div>
                  </div>
                  <div class="gallery-card__meta">
                    <div class="gallery-card__title">{item.caption}</div>
                    <div class="gallery-card__tag">
                      <span class="gallery-card__tag-dot"></span>
                      <span class="gallery-card__tag-label">{item.categoryLabel}</span>
                    </div>
                  </div>
                </button>
              ))}
            </div>
          </div>

          <p class="gallery__video-note">
            А ниже — короткие видео о спектаклях и жизни студии.
          </p>

          <div class="gallery__video" aria-label="Видео о театре «Эмоцика»">
            <div class="gallery__video-item">
              <iframe src="https://vk.com/video_ext.php?oid=-58293658&id=456241867"
                title="Фильм «День матери» — Киношкола «Эмоция»" loading="lazy" allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>

            <div class="gallery__video-item gallery__video-item--cta">
              <div class="gallery__video-card">
                <p class="gallery__video-card-title">Больше видео во «ВКонтакте»</p>
                <p class="gallery__video-card-text">
                  Трейлеры спектаклей, фильмы КиноШколы «Эмоция» и короткие отзывы родителей — публикуем их в сообществе
                  театра.
                </p>
                <a class="btn btn-secondary" href="https://vk.com/teatr.emocika" target="_blank" rel="noopener">
                  Смотреть в VK Видео
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 
    ========================================================================
    Блок документов
    ========================================================================
    -->
    <section id="docs" class="section section-docs section-card">
      <div class="section-inner">
        <div class="container">
          <header class="section-header">
            <h2 class="section-title">Документы</h2>
            <p class="section-subtitle">
              Все официальные бумаги театра «Эмоция» доступны для скачивания.
            </p>
            <div class="section-chips">
              <span class="chip">Лицензия</span>
              <span class="chip">Договор</span>
              <span class="chip">PDF</span>
            </div>
          </header>

          <div class="docs">
            <ul class="docs-list">
              <li class="docs-item">
                <a href="/assets/docs/license.pdf" class="docs-link" target="_blank" rel="noopener noreferrer">
                  <span class="docs-title">
                    Лицензия на образовательную деятельность
                  </span>
                  <span class="docs-meta">
                    PDF, 2.3&nbsp;МБ
                  </span>
                </a>
              </li>

              <li class="docs-item">
                <a href="/assets/docs/contract-sample.pdf" class="docs-link" target="_blank" rel="noopener noreferrer">
                  <span class="docs-title">
                    Образец договора с родителями
                  </span>
                  <span class="docs-meta">
                    PDF, 1.1&nbsp;МБ
                  </span>
                </a>
              </li>
            </ul>

            <p class="docs-note">
              Актуальные версии документов всегда лежат здесь. При изменениях мы обновляем файлы.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 
    ========================================================================
    Блок FAQ
    ========================================================================
    -->
    <section id="faq" class="section section--faq section-card reveal-on-scroll">
      <div class="section-inner">
        <div class="container">
          <header class="section-header">
            <h2 class="section-title">Частые вопросы</h2>
            <p class="section-subtitle">
              Мы собрали ответы на самые частые вопросы родителей о занятиях, спектаклях и записи в студию.
            </p>
            <div class="section-chips">
              <span class="chip">Возраст и группы</span>
              <span class="chip">Расписание</span>
              <span class="chip">Стоимость</span>
            </div>
          </header>

          <div class="faq">
            <div class="faq-search" data-faq-search>
              <label class="faq-search__field">
                <span>Найдите ответ</span>
                <input type="search" placeholder="Например: оплата, возраст, расписание" data-faq-query />
              </label>
              <div class="faq-search__meta">
                <span class="faq-search__hint">Мы будем подсвечивать подходящие вопросы по мере набора.</span>
                <button type="button" class="btn btn-ghost btn-compact-mobile" data-faq-reset>Сбросить</button>
                <span class="faq-search__count" data-faq-count aria-live="polite"></span>
              </div>
            <div class="faq-list-wrapper">
          <FaqList faqItems={faqData} />
        </div>

          </div>
        </div>
    </section>

    <!-- 
    ========================================================================
    Блок с филиалами
    ========================================================================
    -->
    <section id="branches" class="section section-branches reveal-on-scroll">
      <div class="container">
        <div class="branches-top-layout">
          <div class="branches-top-main">
            <header class="branches-header">
              <p class="section-kicker">Где проходят занятия</p>
              <h2 class="section-title">Филиалы и площадки</h2>
              <p class="section-intro">
                Занятия студии «Эмоция» и театра «Эмоцика» проходят в разных районах
                Петербурга и в Кудрово. Выберите удобную площадку и уточните расписание у администратора.
              </p>
              <div class="section-chips section-chips--left">
                <span class="chip">15 филиалов</span>
                <span class="chip">Метро рядом</span>
                <span class="chip">Кудрово</span>
              </div>
            </header>

            <div class="branches-preferences">
              <label class="branches-my-metro">
                <span class="branches-my-metro-label">Моя станция метро:</span>
                <select class="branches-filter__select" data-branch-my-metro aria-label="Выберите вашу станцию метро">
                <option value="">Не выбрано</option>
                {(() => {
                   const uniqueMetros = [...new Set(sortedBranches.map(b => b.metro).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'ru'));
                   return uniqueMetros.map(metro => (
                     <option value={metro}>{metro}</option>
                   ));
                })()}
              </select>
              </label>
              <p class="branches-my-metro-hint">
                Мы подсветим карточки с этой станцией метро.
              </p>
            </div>

            <div class="branches-filters" aria-label="Фильтр по филиалам">
              <button type="button" class="branches-filter is-active" data-branch-filter="all">
                Все филиалы
              </button>
              <button type="button" class="branches-filter" data-branch-filter="adults">
                Группы 18+
              </button>
            </div>
          </div>

          <figure class="branches-map">
            <img src="/assets/img/branches-map.svg"
              alt="Карта с отмеченными районами, где проходят занятия студии «Эмоция»" class="branches-map-image" />
            <figcaption class="branches-map-legend">
              <p class="branches-map-legend-title">Районы, где идут занятия:</p>
              <div class="branches-map-legend" data-branches-areas>
              {(() => {
                const uniqueAreas = [...new Set(sortedBranches.map(b => b.area).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'ru'));
                if (uniqueAreas.length === 0) return <li class="branches-area-item">Санкт-Петербург и Кудрово</li>;
                return uniqueAreas.map(area => (
                  <li class="branches-area-item">{area}</li>
                ));
              })()}
            </div>
            </figcaption>
          </figure>
        </div>

          <BranchesGrid branches={sortedBranches} />

        <p class="branches-note">
          Полный список филиалов и набор в группы уточняйте у администратора —
          расписание может меняться в течение года.
          <a href="/about#contacts" class="branches-note-link">
            Перейти к контактам администратора →
          </a>
        </p>
      </div>
    </section>

    <section id="contacts" class="section section--contacts section-card">
      <div class="section-inner">
        <div class="container contacts">
          <div class="contacts__info card-luxe">
            <header class="section-header section-header--left">
              <h2 class="section-title">Контакты</h2>
              <p class="contacts__text section-subtitle">Записаться на пробное занятие, уточнить расписание или задать
                любой вопрос можно у администратора театра и студии.</p>
              <div class="section-chips section-chips--left">
                <span class="chip">Звонки и WhatsApp</span>
                <span class="chip">11:00–20:00</span>
                <span class="chip">ТРК «Гранд Каньон»</span>
              </div>
            </header>
            <dl class="contacts__list">
              <div class="contacts__row">
                <dt>Телефон:</dt>
                <dd>
                  <a href="tel:+79313157787">+7 (931) 315-77-87</a>
                  <span class="contacts__note">— звонки и WhatsApp</span>
                </dd>
              </div>
              <div class="contacts__row">
                <dt>Email:</dt>
                <dd><a href="mailto:info@emozia.ru">info@emozia.ru</a></dd>
              </div>
              <div class="contacts__row">
                <dt>Адрес сцены:</dt>
                <dd>Санкт-Петербург, проспект Энгельса, 154, ТРК «Гранд Каньон», 3-й этаж</dd>
              </div>
            </dl>
            <p class="contacts__note">Занятия студии проходят в нескольких филиалах Санкт-Петербурга — подберём удобную
              площадку и время для вашей семьи.</p>
            <p class="contacts__time">Мы на связи ежедневно с 11:00 до 20:00.</p>
            <p class="contacts__note">В рабочие часы быстрее отвечаем в WhatsApp.</p>
            <div class="contacts__actions">
              <a href="https://wa.me/79313157787" class="btn btn-primary" target="_blank" rel="noopener">
                <img src="/assets/img/ui/whatsapp-icon.svg" alt="" class="icon" />
                Написать в WhatsApp
              </a>
              <a href="https://vk.com/teatr.emocika" class="btn btn-outline" target="_blank" rel="noopener">Мы
                во ВКонтакте</a>
            </div>
          </div>
          <div class="contacts__map card-luxe">
            <iframe
              src="https://yandex.ru/map-widget/v1/?ll=30.333187%2C60.059865&z=17&l=map&pt=30.333187,60.059865,pm2rdm"
              loading="lazy" title="Карта проезда в театр «Эмоцика»" frameborder="0" allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>
