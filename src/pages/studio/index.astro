---
import Layout from '../../layouts/Layout.astro';
import PeopleSection from '../../components/PeopleSection.astro';
import peopleData from '../../data/people.json';
import abonementsData from '../../data/abonements.json';
import filmsData from '../../data/films.json';
import StudioFAQ from '../../components/studio/StudioFAQ.astro';

const activeFilm = filmsData[0];

---

<Layout title="Студия и Киношкола | Театр «Эмоцика»" description="Театральная студия и киношкола для детей 4-16 лет. Занятия актерским мастерством, съемки в кино, участие в фестивалях. 15 филиалов в СПб.">
  <main id="main-content">
    <section class="section section-page-header">
      <div class="container">
        <h1 class="page-title">Студия</h1>
      </div>
    </section>
    <section id="tracks" class="section section-tracks reveal-on-scroll">
      <div class="container">
        <header class="section-header">
          <p class="section-kicker">Выберите, что вам важно сейчас</p>
          <h2 class="section-title section-title--handdrawn">Два направления</h2>
          <p class="section-subtitle">
            «Эмоцика» — это одновременно независимый театр и студия с киносъёмками
            для детей и подростков.
          </p>
        </header>

        <div class="tracks-grid">
          <article class="track-card track-card-theatre card-luxe">
            <h3 class="track-title">
              <span class="track-title-icon track-title-icon--theatre" aria-hidden="true"></span>
              Театр «Эмоцика»
            </h3>
            <p class="track-tagline">Спектакли для семей и школьных классов</p>
            <p class="track-text">
              Камерные спектакли, новогодние квесты и премьеры сезона.
              Зал на 50 мест, где каждый зритель — участник события.
            </p>
            <a href="/afisha" class="track-link">
              Смотреть афишу
            </a>
            <div class="track-meta">
              <span class="track-meta-chip">6+ / 12+</span>
              <span class="track-meta-chip">Выходные и будни</span>
            </div>
          </article>

          <article class="track-card track-card-school card-luxe">
            <h3 class="track-title">
              <span class="track-title-icon track-title-icon--school" aria-hidden="true"></span>
              Студия и киношкола
            </h3>
            <p class="track-tagline">Актерское мастерство и киносъёмки</p>
            <p class="track-text">
              Группы для детей от 4 до 16 лет. Учимся говорить красиво, держаться на сцене и снимаем настоящее кино.
            </p>
            <button type="button" class="btn btn-outline track-link-button" data-scroll-to="abonements">
              Выбрать группу
            </button>
            <div class="track-meta">
              <span class="track-meta-chip">Пробный урок</span>
              <span class="track-meta-chip">15 филиалов + Кудрово</span>
            </div>
          </article>
        </div>

        <p class="tracks-bridge">
          Часто ребёнок начинает со студии, а потом выходит на сцену театра —
          это единая творческая экосистема «Эмоцики».
        </p>
      </div>
    </section>

    <!-- 
    ========================================================================
    Блок: абонементы и форматы занятий в студии
    ========================================================================
    -->
    <section id="abonements" class="section section-abonements reveal-on-scroll">
      <div class="container">
        <header class="section-header">
          <p class="section-kicker">Форматы занятий</p>
          <h2 class="section-title">Абонементы студии</h2>
          <p class="section-subtitle">
            От разовых мастер-классов до годового обучения. Подберем группу под возраст и опыт ребёнка.
          </p>
        </header>

        </header>

        <div class="abonements-grid" data-abonements-root>
          {(abonementsData || []).map(item => (
            <article 
              class={`abonement-card ${item.highlight || item.isHero ? 'abonement-card--highlight' : ''} ${item.isHero ? 'abonement-card--hero' : ''}`}
              data-abonement-id={item.id}
              aria-label={item.isHero ? `${item.name}. Чаще всего родители выбирают именно этот формат.` : undefined}
            >
              {item.tagLine && <p class="abonement-tagline">{item.tagLine}</p>}
              <h3 class="abonement-name">{item.name}</h3>
              {item.age && <p class="abonement-age">{item.age}</p>}
              {item.description && <p class="abonement-description">{item.description}</p>}
              
              {item.bullets && item.bullets.length > 0 && (
                <ul class="abonement-list">
                  {(item.bullets || []).map(bullet => <li>{bullet}</li>)}
                </ul>
              )}
              
              <div class="abonement-bottom">
                {item.price && <p class="abonement-price">{item.price}</p>}
                {item.note && <p class="abonement-note">{item.note}</p>}
              </div>
              
              {item.badge && <span class="abonement-badge">{item.badge}</span>}
            </article>
          ))}
        </div>

        <section class="abonement-picker card-luxe" data-abonement-picker>
          <div class="abonement-picker__intro">
            <h3 class="abonement-picker__title">Подобрать формат</h3>
            <p class="abonement-picker__text">
              Укажите параметры — подскажем, с чего лучше начать.
            </p>
          </div>

          <div class="abonement-picker__form">
            <div class="abonement-picker__group">
              <span class="abonement-picker__label">Возраст ребёнка</span>
              <div class="abonement-chips" data-abonement-age>
                <label class="radio-chip">
                  <input type="radio" name="age" value="4-6" />
                  <span class="radio-chip__text">4–6 лет</span>
                </label>
                <label class="radio-chip">
                  <input type="radio" name="age" value="7-11" checked />
                  <span class="radio-chip__text">7–11 лет</span>
                </label>
                <label class="radio-chip">
                  <input type="radio" name="age" value="12-16" />
                  <span class="radio-chip__text">12–16 лет</span>
                </label>
                <label class="radio-chip">
                  <input type="radio" name="age" value="17plus" />
                  <span class="radio-chip__text">Взрослые</span>
                </label>
              </div>
            </div>

            <div class="abonement-picker__group">
              <span class="abonement-picker__label">Цель занятий</span>
              <div class="abonement-chips" data-abonement-goal>
                <label class="radio-chip">
                  <input type="radio" name="goal" value="stage" checked />
                  <span class="radio-chip__text">Сцена и уверенность</span>
                </label>
                <label class="radio-chip">
                  <input type="radio" name="goal" value="cinema" />
                  <span class="radio-chip__text">Кино и съёмки</span>
                </label>
                <label class="radio-chip">
                  <input type="radio" name="goal" value="speech" />
                  <span class="radio-chip__text">Речь и общение</span>
                </label>
              </div>
            </div>

            <div class="abonement-picker__group">
              <span class="abonement-picker__label">График</span>
              <div class="abonement-chips" data-abonement-schedule>
                <label class="radio-chip">
                  <input type="radio" name="schedule" value="light" />
                  <span class="radio-chip__text">1 раз</span>
                </label>
                <label class="radio-chip">
                  <input type="radio" name="schedule" value="standard" checked />
                  <span class="radio-chip__text">2 раза</span>
                </label>
                <label class="radio-chip">
                  <input type="radio" name="schedule" value="intense" />
                  <span class="radio-chip__text">Интенсив</span>
                </label>
              </div>
            </div>
          </div>

          <div class="abonement-picker__result" data-abonement-result aria-live="polite">
            <div class="abonement-picker__badge" data-abonement-result-badge>Рекомендация</div>
            <div>
              <p class="abonement-picker__result-title" data-abonement-result-title>Пробное занятие</p>
              <p class="abonement-picker__result-text" data-abonement-result-text>
                Начните с пробного урока.
              </p>
              <div class="abonement-picker__actions">
                <a href="/about#contacts" class="btn btn-secondary btn-compact-mobile" data-scroll-to="contacts"
                  data-abonement-cta-main>
                  Записаться
                </a>
              </div>
            </div>
          </div>
        </section>

        <div class="section-abonements-cta">
          <div class="section-abonements-cta-text">
            <h3 class="section-abonements-cta-title">
              Нужна помощь с выбором?
            </h3>
            <p class="section-abonements-cta-subtitle">
              Оставьте заявку — администратор свяжется и подскажет лучшую группу.
            </p>
          </div>

          <div class="section-abonements-cta-actions">
            <button type="button" class="btn btn-primary section-abonements-cta-main" data-scroll-to="contacts"
              data-cta="abonements-main">
              Оставить заявку
            </button>
          </div>
        </div>
      </div>
    </section>

    <section id="studio" class="section section-studio reveal-on-scroll">
      <div class="studio-decor" aria-hidden="true"></div>
      <div class="container">
        <div id="studio-hero" class="studio-hero reveal-on-scroll reveal-studio-1">
          <header class="section-header section-header--left">
            <p class="section-kicker eyebrow eyebrow--dark">Оглавление</p>
            <h2 class="section-title">Обучение в театральной студии и киношколе</h2>
            <p class="section-subtitle">
              Два маршрута для детей: сцена и кино. Ниже — как устроены занятия и пути учеников.
            </p>
            <div class="section-chips section-chips--left">
              <span class="chip">4–16 лет</span>
              <span class="chip">1–2 раза в неделю</span>
              <span class="chip">Сцена + кино</span>
            </div>
          </header>
        </div>

        <!-- Этаж 2: две карточки "Театр" и "Студия" -->
        <div class="studio-duo reveal-on-scroll reveal-studio-2" aria-label="Театр и студия">
          <article class="studio-column studio-column--theatre">
            <header class="studio-track-header">
              <div class="studio-track-icon studio-track-icon--theatre" aria-hidden="true"></div>
              <div class="studio-track-title">
                <h3 class="studio-track-name">Театральная студия</h3>
                <p class="studio-track-caption">
                  Регулярные занятия и спектакли на сцене нашего театра.
                </p>
              </div>
            </header>

            <div class="studio-track-overview">
              <p>
                Дети занимаются актёрским мастерством, речью и пластикой в группах по возрасту,
                репетируют сцены и готовят спектакли.
              </p>
              <p>
                В конце сезона ребята выходят на сцену нашего театра в настоящем спектакле.
              </p>
            </div>

            <section class="studio-track-path" aria-label="Путь ученика в театральной студии" data-timeline="theatre"
              data-autoplay="true">
              <h4 class="studio-track-path-title">
                Путь ученика в студии
              </h4>

              <ol class="timeline timeline--vertical">
                <li class="timeline-step timeline-step--active" data-step="1">
                  <div class="timeline-step-marker">
                    <span class="timeline-step-number">1</span>
                  </div>
                  <div class="timeline-step-body">
                    <h5 class="timeline-step-title">Первое знакомство</h5>
                    <p class="timeline-step-text">
                      Пробное занятие, знакомство с педагогом, группой и сценой через игровые упражнения.
                    </p>
                  </div>
                </li>

                <li class="timeline-step" data-step="2">
                  <div class="timeline-step-marker">
                    <span class="timeline-step-number">2</span>
                  </div>
                  <div class="timeline-step-body">
                    <h5 class="timeline-step-title">Занятия и тренинг</h5>
                    <p class="timeline-step-text">
                      Регулярные уроки по актёрскому мастерству, речи и пластике,
                      работа в сценах и этюдах.
                    </p>
                  </div>
                </li>

                <li class="timeline-step" data-step="3">
                  <div class="timeline-step-marker">
                    <span class="timeline-step-number">3</span>
                  </div>
                  <div class="timeline-step-body">
                    <h5 class="timeline-step-title">Репетиции спектакля</h5>
                    <p class="timeline-step-text">
                      Сборка спектакля: репетируем сцены, примеряем костюмы,
                      привыкаем к сцене, свету и залу.
                    </p>
                  </div>
                </li>

                <li class="timeline-step" data-step="4">
                  <div class="timeline-step-marker">
                    <span class="timeline-step-number">4</span>
                  </div>
                  <div class="timeline-step-body">
                    <h5 class="timeline-step-title">Премьера на сцене</h5>
                    <p class="timeline-step-text">
                      Показ спектакля для зрителей на сцене театра —
                      первый большой сценический опыт ребёнка.
                    </p>
                  </div>
                </li>
              </ol>
            </section>
          </article>

          <article class="studio-column studio-column--films">
            <header class="studio-track-header">
              <div class="studio-track-icon studio-track-icon--films" aria-hidden="true"></div>
              <div class="studio-track-title">
                <h3 class="studio-track-name">Киношкола</h3>
                <p class="studio-track-caption">
                  Съёмки с детьми и готовые фильмы в Петербурге и Москве.
                </p>
              </div>
            </header>

            <div class="studio-track-overview">
              <p>
                Дети попадают в съёмочную команду, пробуют себя в кадре
                и учатся работать перед камерой.
              </p>
              <p>
                Мы снимаем короткие фильмы и проекты, которые монтируем
                и показываем зрителям в Санкт-Петербурге и Москве.
              </p>
            </div>

            <section class="studio-track-path" aria-label="Путь ученика в киношколе" data-timeline="films"
              data-autoplay="true">
              <h4 class="studio-track-path-title">
                Путь ученика в киношколе
              </h4>

              <ol class="timeline timeline--vertical">
                <li class="timeline-step timeline-step--active" data-step="1">
                  <div class="timeline-step-marker">
                    <span class="timeline-step-number">1</span>
                  </div>
                  <div class="timeline-step-body">
                    <h5 class="timeline-step-title">Знакомство и пробы</h5>
                    <p class="timeline-step-text">
                      Пробы, первые упражнения перед камерой, знакомство
                      с командой и форматом съёмок.
                    </p>
                  </div>
                </li>

                <li class="timeline-step" data-step="2">
                  <div class="timeline-step-marker">
                    <span class="timeline-step-number">2</span>
                  </div>
                  <div class="timeline-step-body">
                    <h5 class="timeline-step-title">Подготовка и сценарий</h5>
                    <p class="timeline-step-text">
                      Обсуждаем историю и роли, разбираем сцены,
                      репетируем перед съёмочным днём.
                    </p>
                  </div>
                </li>

                <li class="timeline-step" data-step="3">
                  <div class="timeline-step-marker">
                    <span class="timeline-step-number">3</span>
                  </div>
                  <div class="timeline-step-body">
                    <h5 class="timeline-step-title">Съёмочный день</h5>
                    <p class="timeline-step-text">
                      Работа на площадке: камера, свет, несколько дублей,
                      команды «мотор» и «стоп», живой съёмочный процесс.
                    </p>
                  </div>
                </li>

                <li class="timeline-step" data-step="4">
                  <div class="timeline-step-marker">
                    <span class="timeline-step-number">4</span>
                  </div>
                  <div class="timeline-step-body">
                    <h5 class="timeline-step-title">Монтаж и премьера</h5>
                    <p class="timeline-step-text">
                      Фильм монтируется, и ребёнок видит себя на экране
                      на показе или фестивальном просмотре.
                    </p>
                  </div>
                </li>
              </ol>
            </section>
          </article>
        </div>

        <!-- Этаж 4: как мы учим и на что опираемся -->
        <div id="studio-values" class="studio-values reveal-on-scroll reveal-studio-4"
          aria-label="Как мы учим и чему уделяем внимание">
          <div class="studio-values-header">
            <h3 class="studio-values-title heading-with-scribble">Как мы учим</h3>
            <p class="studio-values-lead">
              В основе занятий — игра, бережное отношение к психике ребёнка и проектный формат.
              Всё это помогает детям безопасно пробовать себя на сцене и в кадре.
            </p>
          </div>

          <div class="studio-values-grid">
            <article class="studio-value-card">
              <div class="studio-value-badge badge badge--soft">Через игру</div>
              <h4 class="studio-value-title">Живое действие вместо «занятий по учебнику»</h4>
              <p class="studio-value-text">
                Ребёнок осваивает актёрские навыки через игры, этюды и маленькие сцены.
                Никаких сухих упражнений — только живое действие, эмоции и партнёрство.
              </p>
            </article>

            <article class="studio-value-card">
              <div class="studio-value-badge badge badge--soft">Бережно</div>
              <h4 class="studio-value-title">Безопасная атмосфера и поддержка</h4>
              <p class="studio-value-text">
                Педагоги следят за эмоциональным состоянием детей,
                не ломают характер и не заставляют «играть через страх».
                Важнее доверие, чем идеальный текст.
              </p>
            </article>

            <article class="studio-value-card">
              <div class="studio-value-badge badge badge--soft">Проектно</div>
              <h4 class="studio-value-title">Спектакли, фильмы и лагерные проекты</h4>
              <p class="studio-value-text">
                Учебный год строится вокруг больших проектов: спектаклей, кинолент,
                показов в лагере. Ребёнок видит результат своей работы и гордится им.
              </p>
            </article>

            <article class="studio-value-card">
              <div class="studio-value-badge badge badge--soft">Команда</div>
              <h4 class="studio-value-title">Практикующие артисты и педагоги</h4>
              <p class="studio-value-text">
                С детьми работают режиссёры, актёры и педагоги, которые сами выходят на сцену
                и снимаются в кино. Они делятся не только знаниями, но и живым профессиональным опытом.
              </p>
            </article>
          </div>
        </div>

        <div class="studio-meta-row">
          <div class="studio-meta-block">
            <div class="studio-meta-block-title">Возрастные группы</div>
            <p>
              Занятия для детей от 3 до 16 лет и взрослых 18+. Группы формируются по возрасту и уровню
              подготовки: 3–5 лет, младшие школьники, подростки и отдельная группа для взрослых.
            </p>
          </div>
          <div class="studio-meta-block">
            <div class="studio-meta-block-title">Формат и расписание</div>
            <p>
              Занятия проходят 1–2 раза в неделю по будням после школы или в выходные.
              Продолжительность занятия — около 1,5 часа.
            </p>
          </div>
          <div class="studio-meta-block">
            <div class="studio-meta-block-title">Филиалы и лагеря</div>
            <p>
              У студии около 15 филиалов по Санкт-Петербургу, родители выбирают удобную локацию.
              Летом проходят выездные театральные лагеря с подготовкой спектакля за смену.
            </p>
          </div>
        </div>

        <!-- Блок Где проходят занятия и показы -->
        <div class="studio-theatre-intro">
          <p class="section-kicker">Театр-студия</p>

          <h3 class="studio-theatre-heading">
            Где проходят занятия и показы
          </h3>

          <div class="studio-theatre-text">
            <p>
              Мы работаем с детьми от 3,5 до 16 лет уже 10,5 лет.
            </p>
            <p>
              Занятия театральной студии проходят в 15 филиалах по Санкт-Петербургу.
            </p>
            <p>
              Показы спектаклей проходят на сцене нашего театра.
            </p>
            <p>
              Кино с детьми мы снимаем в Санкт-Петербурге и Москве.
            </p>
          </div>

          <button type="button" class="btn btn-outline studio-theatre-branches" data-scroll-to="branches">
            Посмотреть филиалы
          </button>
        </div>

        <p class="studio-note">
          Первое занятие обычно пробное — можно прийти, познакомиться с педагогами и форматом работы.
          После пробного урока ребёнка распределяют в подходящую группу по возрасту и опыту.
        </p>

        <!-- Этаж 6: финальный CTA-блок -->
        <div class="studio-cta reveal-on-scroll reveal-studio-6">
          <div class="studio-cta-shell">
            <p class="studio-cta-eyebrow">Готовы познакомиться ближе?</p>
            <h3 class="studio-cta-title">Сделаем первый шаг вместе</h3>

            <p class="studio-cta-text">
              У нас дети сначала пробуют себя на занятиях, выходят на сцену в спектаклях, попадают в фильмы
              и фестивали. Можно начать с театральной студии — или сразу с киношколы.
            </p>

            <div class="studio-cta-grid">
              <!-- Карточка 1: театральная студия -->
              <article class="studio-cta-card">
                <div class="studio-cta-card-header">
                  <div class="studio-cta-icon studio-cta-icon--stage" aria-hidden="true"></div>
                  <div>
                    <h4 class="studio-cta-card-title">Хочу в театральную студию</h4>
                    <p class="studio-cta-card-tags">
                      Группы 4–16 лет • 1–2 раза в неделю • спектакли на сцене
                    </p>
                  </div>
                </div>

                <p class="studio-cta-card-text">
                  Поможем выбрать филиал, группу и педагога, расскажем про расписание и пригласим на пробное занятие.
                </p>

                <div class="studio-cta-card-actions">
                  <a href="/about#contacts" class="btn btn-primary" data-scroll-to="contacts">
                    Записаться в студию
                  </a>
                </div>
              </article>

              <!-- Карточка 2: киношкола -->
              <article class="studio-cta-card">
                <div class="studio-cta-card-header">
                  <div class="studio-cta-icon studio-cta-icon--studio" aria-hidden="true"></div>
                  <div>
                    <h4 class="studio-cta-card-title">Хочу в киношколу</h4>
                    <p class="studio-cta-card-tags">
                      Съёмки короткометражек • фестивали • кинолагеря
                    </p>
                  </div>
                </div>

                <p class="studio-cta-card-text">
                  Расскажем про съёмки, проекты и фестивали, подскажем, с какого формата лучше начать именно вашему
                  ребёнку.
                </p>

                <div class="studio-cta-card-actions">
                  <a href="/about#contacts" class="btn btn-secondary btn-secondary--dark" data-scroll-to="contacts">
                    Обсудить киноформат
                  </a>
                </div>
              </article>
            </div>

            <p class="studio-cta-note">
              Вы школа, лагерь или площадка?
