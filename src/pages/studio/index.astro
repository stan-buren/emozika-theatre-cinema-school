---
import Layout from '../../layouts/Layout.astro';
import PeopleSection from '../../components/PeopleSection.astro';
import abonementsData from '../../data/abonements.json';
import StudioFAQ from '../../components/studio/StudioFAQ.astro';

// Filter out "Cinema" goal from calculator logic if needed, 
// for now we just change the UI to focus on theatre.
---

<Layout title="Театральная Студия Эмоцика | Развитие через сцену" description="Театральная студия для детей от 4 до 16 лет. Спектакли на профессиональной сцене, костюмы включены, филиалы во всех районах СПб." theme="studio">
  <main id="main-content">
    
    <!-- Hero Section -->
    <section class="section section-page-header">
      <div class="container">
        <h1 class="page-title">Театральная Студия</h1>
        <p class="text-xl mt-4 max-w-2xl">
            Место, где ребенок обретает уверенность, друзей и веру в себя через магию театра.
        </p>
      </div>
    </section>

    <!-- NEW: Pain Points Solver (All Inclusive) -->
    <section class="section bg-white py-16">
        <div class="container">
            <div class="bg-[#fcfbf9] border border-[#eec550]/20 rounded-3xl p-8 md:p-12 shadow-sm">
                <h2 class="text-3xl font-bold mb-8 text-center">Почему мамы выбирают «Эмоцику»?</h2>
                <div class="grid md:grid-cols-3 gap-8">
                    <div class="flex flex-col items-center text-center">
                        <div class="text-4xl mb-4">👗</div>
                        <h3 class="font-bold text-xl mb-2">Костюмерная включена</h3>
                        <p class="text-gray-600">Вам не нужно шить костюмы ночами или искать реквизит. Мы всё предоставляем сами.</p>
                    </div>
                    <div class="flex flex-col items-center text-center">
                        <div class="text-4xl mb-4">📸</div>
                        <h3 class="font-bold text-xl mb-2">Контент в подарок</h3>
                        <p class="text-gray-600">Профессиональные фото и видео со спектаклей уже включены в абонемент.</p>
                    </div>
                    <div class="flex flex-col items-center text-center">
                        <div class="text-4xl mb-4">🎭</div>
                        <h3 class="font-bold text-xl mb-2">Своя сцена</h3>
                        <p class="text-gray-600">Мы не арендуем ДК. Дети выступают на профессиональной сцене в Гранд Каньоне.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Abonements & Calculator -->
    <section id="abonements" class="section section-abonements reveal-on-scroll">
      <div class="container">
        <header class="section-header">
          <p class="section-kicker">Форматы обучения</p>
          <h2 class="section-title">Абонементы студии</h2>
          <p class="section-subtitle">
            Группы разделены по возрасту. В каждой — не более 15 человек, чтобы уделить внимание каждому.
          </p>
        </header>

        <div class="abonements-grid" data-abonements-root>
          {(abonementsData || []).map(item => (
            <article 
              class={`abonement-card ${item.highlight || item.isHero ? 'abonement-card--highlight' : ''} ${item.isHero ? 'abonement-card--hero' : ''}`}
              data-abonement-id={item.id}
            >
              {item.tagLine && <p class="abonement-tagline">{item.tagLine}</p>}
              <h3 class="abonement-name">{item.name}</h3>
              {item.age && <p class="abonement-age">{item.age}</p>}
              {item.description && <p class="abonement-description">{item.description}</p>}
              
              {item.bullets && item.bullets.length > 0 && (
                <ul class="abonement-list">
                  {(item.bullets || []).map(bullet => <li>{bullet}</li>)}
                </ul>
              )}
              
              <div class="abonement-bottom">
                {item.price && <p class="abonement-price">{item.price}</p>}
                {item.note && <p class="abonement-note">{item.note}</p>}
              </div>
              
              {item.badge && <span class="abonement-badge">{item.badge}</span>}
            </article>
          ))}
        </div>

        <!-- Calculator (Simplified for Studio) -->
        <section class="abonement-picker card-luxe" data-abonement-picker>
          <div class="abonement-picker__intro">
            <h3 class="abonement-picker__title">Подобрать группу</h3>
            <p class="abonement-picker__text">
              Укажите возраст ребёнка — мы подскажем расписание.
            </p>
          </div>

          <div class="abonement-picker__form">
            <div class="abonement-picker__group">
              <span class="abonement-picker__label">Возраст ребёнка</span>
              <div class="abonement-chips" data-abonement-age>
                <label class="radio-chip">
                  <input type="radio" name="age" value="4-6" />
                  <span class="radio-chip__text">4–6 лет</span>
                </label>
                <label class="radio-chip">
                  <input type="radio" name="age" value="7-11" checked />
                  <span class="radio-chip__text">7–11 лет</span>
                </label>
                <label class="radio-chip">
                  <input type="radio" name="age" value="12-16" />
                  <span class="radio-chip__text">12–16 лет</span>
                </label>
                 <label class="radio-chip">
                  <input type="radio" name="age" value="17plus" />
                  <span class="radio-chip__text">Взрослые</span>
                </label>
              </div>
            </div>

             <!-- Removed "Goal" and "Schedule" for simplicity in this version, can add back if needed -->
             
             <div class="abonement-picker__actions mt-6">
                <a href="/about#contacts" class="btn btn-primary w-full md:w-auto" data-scroll-to="contacts">
                  Записаться на пробное
                </a>
             </div>
          </div>
        </section>
      </div>
    </section>

    <!-- Studio Journey (Only Theatre Track) -->
    <section id="studio-journey" class="section reveal-on-scroll">
      <div class="container">
          <div class="studio-column studio-column--theatre mx-auto max-w-4xl">
            <header class="studio-track-header text-center mb-12">
              <div class="studio-track-title">
                <h2 class="text-3xl font-bold mb-4">Путь вашего ребенка</h2>
                <p class="text-xl text-gray-600">
                  От первого шага в зал до премьеры на большой сцене
                </p>
              </div>
            </header>

            <section class="studio-track-path" aria-label="Путь ученика" data-timeline="theatre">
               <ol class="timeline timeline--vertical">
                <li class="timeline-step timeline-step--active">
                  <div class="timeline-step-marker"><span class="timeline-step-number">1</span></div>
                  <div class="timeline-step-body">
                    <h5 class="timeline-step-title">Знакомство (Сентябрь)</h5>
                    <p class="timeline-step-text">Игровой тренинг, снятие зажимов, поиск друзей.</p>
                  </div>
                </li>
                 <li class="timeline-step">
                  <div class="timeline-step-marker"><span class="timeline-step-number">2</span></div>
                  <div class="timeline-step-body">
                    <h5 class="timeline-step-title">Показ этюдов (Декабрь)</h5>
                    <p class="timeline-step-text">Первый выход к зрителю. Открытый урок для родителей.</p>
                  </div>
                </li>
                 <li class="timeline-step">
                  <div class="timeline-step-marker"><span class="timeline-step-number">3</span></div>
                  <div class="timeline-step-body">
                    <h5 class="timeline-step-title">Большая репетиция (Весна)</h5>
                    <p class="timeline-step-text">Работа над ролью, примерка костюмов (которые мы сшили!).</p>
                  </div>
                </li>
                 <li class="timeline-step">
                  <div class="timeline-step-marker"><span class="timeline-step-number">4</span></div>
                  <div class="timeline-step-body">
                    <h5 class="timeline-step-title">Премьера спектакля (Май)</h5>
                    <p class="timeline-step-text">Профессиональная сцена, свет, звук, аплодисменты и цветы.</p>
                  </div>
                </li>
              </ol>
            </section>
          </div>
      </div>
    </section>

    <!-- Values Section -->
    <section id="studio-values" class="section reveal-on-scroll">
       <div class="container">
          <div class="studio-values-header text-center mb-12">
            <h2 class="text-3xl font-bold">Наши ценности</h2>
          </div>
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
             <article class="p-6 bg-white rounded-xl shadow-sm border border-gray-100">
               <h4 class="font-bold text-lg mb-2">Безопасность</h4>
               <p class="text-sm text-gray-600">Бережная экологичная среда. Мы не ломаем личности.</p>
             </article>
             <article class="p-6 bg-white rounded-xl shadow-sm border border-gray-100">
               <h4 class="font-bold text-lg mb-2">Игра</h4>
               <p class="text-sm text-gray-600">Учимся играючи. Никакой скучной зубрежки.</p>
             </article>
             <article class="p-6 bg-white rounded-xl shadow-sm border border-gray-100">
               <h4 class="font-bold text-lg mb-2">Команда</h4>
               <p class="text-sm text-gray-600">Театр — это искусство взаимодействия. Учим дружить.</p>
             </article>
             <article class="p-6 bg-white rounded-xl shadow-sm border border-gray-100">
               <h4 class="font-bold text-lg mb-2">Результат</h4>
               <p class="text-sm text-gray-600">Мы нацелены на реальный продукт — спектакль.</p>
             </article>
          </div>
       </div>
    </section>

    <PeopleSection class="reveal-on-scroll" />

    <section id="contacts" class="section section--contacts section-card">
       <div class="section-inner">
        <div class="container contacts">
          <div class="contacts__info card-luxe">
            <header class="section-header section-header--left">
              <h2 class="section-title">Контакты</h2>
              <p class="contacts__text section-subtitle">Записаться на пробное занятие в студию.</p>
            </header>
            <dl class="contacts__list">
              <div class="contacts__row">
                <dt>Телефон:</dt>
                <dd><a href="tel:+79313157787">+7 (931) 315-77-87</a></dd>
              </div>
              <div class="contacts__row">
                <dt>Адрес сцены:</dt>
                <dd>Санкт-Петербург, ТРК «Гранд Каньон», 3-й этаж</dd>
              </div>
            </dl>
             <div class="contacts__actions">
              <a href="https://wa.me/79313157787" class="btn btn-primary" target="_blank" rel="noopener">
                Написать в WhatsApp
              </a>
            </div>
          </div>
           <div class="contacts__map card-luxe">
            <iframe
              src="https://yandex.ru/map-widget/v1/?ll=30.333187%2C60.059865&z=17&l=map&pt=30.333187,60.059865,pm2rdm"
              loading="lazy" title="Карта проезда в театр «Эмоцика»" frameborder="0" allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </section>

    <StudioFAQ />

  </main>
</Layout>

<style>
    /* Add temporary styles if needed, mostly reusing existing ones */
    .section { padding: 4rem 0; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }
</style>
