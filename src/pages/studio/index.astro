---
import Layout from '../../layouts/Layout.astro';
import PeopleSection from '../../components/PeopleSection.astro';
import BenefitsGrid from '../../components/studio/BenefitsGrid.astro';
import AbonementsGrid from '../../components/studio/AbonementsGrid.astro';
import StudioPathway from '../../components/studio/StudioPathway.astro';
// Migrated Components
import BranchesSection from '../../components/studio/BranchesSection.astro';
import ReviewsSection from '../../components/studio/ReviewsSection.astro';
import FaqSection from '../../components/studio/FaqSection.astro';
---

<Layout title="Театральная Студия Эмоцика | Развитие через сцену" description="Театральная студия для детей от 4 до 16 лет. Спектакли на профессиональной сцене, костюмы включены." theme="studio">
  <main class="studio-page">
    
    <!-- Hero Section -->
    <section class="section section-page-header">
      <div class="container">
        <h1 class="page-title">Театральная Студия</h1>
        <p class="text-xl mt-4 max-w-2xl">
            Место, где ребенок обретает уверенность, друзей и веру в себя через магию театра.
        </p>
      </div>
    </section>

    <!-- 1. Pain Points Solver (Warm Grid) -->
    <BenefitsGrid title="Почему мамы выбирают «Эмоцику»?" />

    <!-- 2. Abonements (Pricing) -->
    <section id="abonements" class="section">
      <div class="container">
        <header class="section-header">
          <h2 class="section-title">Абонементы студии</h2>
          <p class="section-subtitle">
            Группы разделены по возрасту. В каждой — не более 15 человек.
          </p>
        </header>
        
        <AbonementsGrid />
      </div>
    </section>

    <!-- 3. Studio Journey -->
    <section id="studio-journey" class="section section-studio">
      <div class="container">
          <div class="studio-column mx-auto max-w-4xl">
             <div class="text-center mb-10">
                <h2 class="section-title">Путь вашего ребенка</h2>
                <p class="text-xl">От первого робкого шага до громких аплодисментов.</p>
             </div>
             
             <!-- Interactive Timeline -->
             <StudioPathway />
          </div>
      </div>
    </section>

    <!-- 4. People (Team) -->
    <PeopleSection />

    <!-- 5. Branches (Moved from About) -->
    <BranchesSection />

    <!-- 6. Reviews (Moved from About) -->
    <ReviewsSection />

    <!-- 7. Contacts -->
    <section id="contacts" class="section section--contacts">
       <div class="container contacts">
          <div class="contacts__info card-warm">
            <h2 class="section-title">Пора на сцену!</h2>
            <p class="contacts__text section-subtitle mb-8">Запишитесь на бесплатное пробное занятие.</p>
            
            <a href="https://wa.me/79313157787" class="btn-cinema-gold" target="_blank" rel="noopener" style="background: var(--text-accent); color: white; border-radius: 99px;">
              Записаться в WhatsApp
            </a>
          </div>
       </div>
    </section>

    <!-- 8. FAQ (Moved from About) -->
    <FaqSection />

  </main>
</Layout>
