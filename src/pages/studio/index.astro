    <!-- 
    ========================================================================
    Блок: Фильмы и награды Киношколы «Эмоция»
    ========================================================================
    -->
    <section id="films" class="section section-films section-card reveal-on-scroll">
      <div class="section-inner">
        <div class="container">
          <header class="section-header">
            <h2 class="section-title">Фильмы и награды</h2>
            <p class="section-subtitle">
              Короткометражные фильмы Киношколы «Эмоция» и фестивальные победы — живые доказательства того,
              что дети здесь не просто «занимаются для души», а выходят на экран и получают реальные награды.
            </p>
            <div class="section-chips">
              <span class="chip chip--glass">VK Видео</span>
              <span class="chip chip--glass">Фестивальные дипломы</span>
              <span class="chip chip--glass">Премьеры в СПб и Москве</span>
            </div>
          </header>

          <div class="films-shell">
            <!-- Горизонтальная карусель с карточками фильмов -->
            <div class="films-carousel" data-films-carousel>
              {(filmsData || []).map((film, index) => {
                const awards = film.awards || [];
                const visibleAwards = awards.slice(0, 2);
                const extraCount = awards.length > 2 ? awards.length - 2 : 0;
                
                return (
                  <button 
                    type="button" 
                    class={`films-card ${index === 0 ? 'films-card--active' : ''}`}
                    data-film-id={film.id}
                  >
                    <div class="films-card-poster">
                      <div class="films-card-poster-inner">
                        {film.title.charAt(0)}
                      </div>
                    </div>
                    <div class="films-card-main">
                      <h4 class="films-card-title">{film.title}</h4>
                      <p class="films-card-meta">{(film.year || 'Добавить данные') + ' · ' + (film.city || 'Добавить данные')}</p>
                      <p class="films-card-logline">{film.logline}</p>
                      <div class="films-card-awards">
                        {visibleAwards.map(a => {
                           let pillClass = "films-card-award-pill badge badge--soft";
                           if (a.status && /гран[- ]?при/i.test(a.status)) {
                               pillClass = "films-card-award-pill badge badge--gold";
                           }
                           const text = [a.status, a.festival].filter(Boolean).join(" ");
                           return <span class={pillClass}>{text}</span>;
                        })}
                        {extraCount > 0 && (
                           <span class="films-card-award-pill films-card-award-pill--more badge badge--outline">+{extraCount} фестиваля</span>
                        )}
                      </div>
                    </div>
                  </button>
                )
              })}
            </div>

            <aside class="films-detail card-luxe" data-films-detail data-film-detail>
              <div class="films-detail-video">
                <div class="films-video-frame" data-film-embed>
                   {activeFilm.vkEmbedUrl 
                     ? <iframe src={activeFilm.vkEmbedUrl} frameborder="0" allowfullscreen loading="lazy"></iframe>
                     : <div class="films-video-placeholder">Видео появится позже</div>
                   }
                </div>
              </div>

              <div class="films-detail-body">
                <h3 class="films-detail-title" data-film-title>{activeFilm.title}</h3>
                <p class="films-detail-meta" data-film-meta>{(activeFilm.year || 'Добавить данные') + ' · ' + (activeFilm.city || 'Добавить данные')}</p>

                <div class="films-detail-authors" data-film-authors>
                    <span class="films-detail-author">Сценарий: {activeFilm.writer || "Добавить данные"}</span>
                    <span class="films-detail-author">Режиссура: {activeFilm.directors && activeFilm.directors.length ? activeFilm.directors.join(", ") : "Добавить данные"}</span>
                    <span class="films-detail-author">Оператор: {activeFilm.dop || "Добавить данные"}</span>
                    {activeFilm.editor && <span class="films-detail-author">Редактор: {activeFilm.editor}</span>}
                </div>

                <ul class="films-detail-awards" data-film-awards>
                  {activeFilm.awards && activeFilm.awards.length > 0 ? (
                    (activeFilm && activeFilm.awards ? activeFilm.awards : []).map(award => (
                        <li class="films-detail-award">
                            {[award.status, award.festival, award.city && `(${award.city})`, award.year].filter(Boolean).join(", ")}
                        </li>
                    ))
                  ) : (
                    <li class="films-detail-award films-detail-award--empty">Награды будут добавлены позже.</li>
                  )}
                </ul>

                <div class="films-detail-synopsis" data-film-synopsis>{activeFilm.synopsis}</div>

                <a 
                    class="btn btn-ghost films-detail-vk" 
                    data-film-vk-link 
                    target="_blank" 
                    rel="noopener"
                    href={activeFilm.vkPageUrl || activeFilm.vkEmbedUrl}
                    style={!(activeFilm.vkPageUrl || activeFilm.vkEmbedUrl) ? "display: none;" : ""}
                >
                  Смотреть на ВК
                </a>
              </div>
            </aside>
          </div>

          <p class="films-summary">
            Ученики студии регулярно становятся лауреатами фестивалей, а фильмы и спектакли
            получают десятки дипломов и гран-при — для родителей это наглядный показатель уровня подготовки.
          </p>
        </div>
      </div>
    </section>

    <PeopleSection class="reveal-on-scroll" />



