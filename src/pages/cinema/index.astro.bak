---
import Layout from '../../layouts/Layout.astro';
import CinemaHero from '../../components/cinema/CinemaHero.astro';
import TracksSplit from '../../components/cinema/TracksSplit.astro';
import ProfessionsGrid from '../../components/cinema/ProfessionsGrid.astro';
import SuccessStories from '../../components/cinema/SuccessStories.astro';
---

<Layout title="Киношкола Эмоцика | Старт карьеры в кино" description="Киношкола для подростков в Санкт-Петербурге. Актерское мастерство, режиссура, блогинг. Съемки в реальных проектах." theme="dark">
    <main class="cinema-page">
        <!-- Hero: Старт Карьеры -->
        <CinemaHero />
        
        <!-- Tracks: Актер vs Фильммейкер -->
        <TracksSplit />
        
        <!-- Professions: Кем я стану? -->
        <ProfessionsGrid />
        
        <!-- Social Proof: Наши дети на ТВ -->
        <SuccessStories />
        
        <!-- CTA Section -->
        <section class="py-20 bg-black text-center">
            <h2 class="text-4xl font-bold text-accent-gold mb-8">Твой первый дубль – здесь</h2>
            <button class="bg-accent-gold text-black px-8 py-4 rounded-full font-bold text-xl hover:scale-105 transition-transform">
                Записаться на кастинг
            </button>
        </section>
    </main>
</Layout>

<style>
    .cinema-page {
        @apply bg-[#0a0a0a] text-white min-h-screen;
    }
</style>
