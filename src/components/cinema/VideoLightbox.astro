---
---
<dialog id="video-lightbox" class="lightbox">
    <div class="lightbox-content">
        <button class="lightbox-close" aria-label="Close lightbox">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
        <div class="iframe-container">
            <iframe id="lightbox-iframe" src="" allow="autoplay; encrypted-media; fullscreen; picture-in-picture;" frameborder="0" allowfullscreen></iframe>
        </div>
    </div>
</dialog>

<style lang="scss">
    .lightbox {
        display: none; // Force hidden by default
        border: none;
        padding: 0;
        background: transparent;
        width: 100vw;
        height: 100vh;
        max-width: 100vw;
        max-height: 100vh;
        background-color: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(5px);
        
        &::backdrop {
            background-color: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(5px);
        }

        &[open] {
            display: flex;
            align-items: center;
            justify-content: center;
            animation: fadeIn 0.3s ease-out;
        }
    }

    .lightbox-content {
        position: relative;
        width: 90%;
        max-width: 1000px;
        aspect-ratio: 16/9;
        background: #000;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 0 50px rgba(255, 215, 0, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .lightbox-close {
        position: absolute;
        top: -40px;
        right: -10px;
        background: none;
        border: none;
        color: #fff;
        cursor: pointer;
        padding: 8px;
        border-radius: 50%;
        transition: all 0.2s;
        z-index: 10;

        &:hover {
            color: var(--accent-gold, #FFD700);
            transform: scale(1.1);
        }
        
        @media (min-width: 768px) {
            top: 10px;
            right: 10px;
            background: rgba(0, 0, 0, 0.5);
            
            &:hover {
                background: rgba(0, 0, 0, 0.8);
            }
        }
    }

    .iframe-container {
        width: 100%;
        height: 100%;
        
        iframe {
            width: 100%;
            height: 100%;
        }
    }

    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>

<script>
    function initLightbox() {
        const dialog = document.getElementById('video-lightbox') as HTMLDialogElement;
        const iframe = document.getElementById('lightbox-iframe') as HTMLIFrameElement;
        const closeBtn = dialog?.querySelector('.lightbox-close');

        if (!dialog || !iframe) return;

        // Clean up old listeners if any (though Astro usually handles script execution per page logic)
        // Just in case, we can use a fresh reference.

        window.openVideoLightbox = (url) => {
            iframe.src = url;
            dialog.showModal();
            document.body.style.overflow = 'hidden';
        };

        const closeLightbox = () => {
            dialog.close();
            iframe.src = '';
            document.body.style.overflow = '';
        };

        // Remove existing listener to prevent duplicates if init runs multiple times
        closeBtn?.removeEventListener('click', closeLightbox);
        closeBtn?.addEventListener('click', closeLightbox);

        dialog.removeEventListener('click', handleBackdropClick);
        dialog.addEventListener('click', handleBackdropClick);

        function handleBackdropClick(e) {
            if (e.target === dialog) {
                closeLightbox();
            }
        }

        dialog.removeEventListener('cancel', closeLightbox);
        dialog.addEventListener('cancel', closeLightbox);
    }

    // Initialize on page load and after Astro transitions
    document.addEventListener('astro:page-load', initLightbox);
    
    // Initial run fallback
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        initLightbox();
    } else {
        document.addEventListener('DOMContentLoaded', initLightbox);
    }
</script>
