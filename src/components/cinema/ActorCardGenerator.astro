---
---

<section id="actor-card" class="section-dark section-card-generator">
  <div class="container mobile-stack">
    
    <!-- Left: Controls -->
    <div class="generator-controls reveal-on-scroll">
      <div class="controls-header">
        <span class="badge-gold">Интерактив</span>
        <h2 class="section-title">Создай свою Актёрскую Карту</h2>
        <p class="section-subtitle">Почувствуй себя звездой Эмоцики. Загрузи фото, впиши имя и скачай официальную карту резидента.</p>
      </div>

      <div class="form-group">
        <label for="actor-name">Твоё сценическое имя</label>
        <input type="text" id="actor-name" class="input-dark" placeholder="Например: Александр Петров" maxlength="20" />
      </div>

      <div class="form-group">
        <label for="actor-role">Амплуа</label>
        <select id="actor-role" class="input-dark">
          <option value="АКТЁР">Актёр / Актриса</option>
          <option value="РЕЖИССЁР">Режиссёр</option>
          <option value="СЦЕНАРИСТ">Сценарист</option>
          <option value="ОПЕРАТОР">Оператор</option>
          <option value="ЗВЕЗДА">Звезда</option>
        </select>
      </div>

      <div class="form-group">
        <label class="btn-upload">
          <input type="file" id="actor-photo" accept="image/*" hidden />
          <span class="icon">📸</span> Загрузить фото
        </label>
      </div>

      <button id="download-btn" class="btn-cinema-gold" disabled>
        Скачать Карту
      </button>
      
      <button id="reset-btn" class="btn-reset" style="display: none;">
        Сбросить
      </button>
    </div>

    <!-- Right: Preview (Canvas) -->
    <div class="generator-preview reveal-on-scroll">
      <div class="canvas-wrapper">
        <canvas id="card-canvas" width="600" height="800"></canvas>
        <div id="loader" class="loader hidden"></div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .section-card-generator {
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
    background: radial-gradient(circle at 20% 50%, rgba(122, 47, 180, 0.1) 0%, transparent 50%);
  }

  .mobile-stack {
    display: flex;
    gap: 4rem;
    align-items: center;

    @media (max-width: 900px) {
      flex-direction: column-reverse;
      gap: 3rem;
    }
  }

  .generator-controls {
    flex: 1;
    min-width: 300px;
  }

  .controls-header {
    margin-bottom: 2.5rem;
  }

  .badge-gold {
    background: var(--accent-gold);
    color: #000;
    font-weight: 700;
    font-size: 0.75rem;
    padding: 4px 12px;
    border-radius: 99px;
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: inline-block;
  }

  .form-group {
    margin-bottom: 1.5rem;

    label {
      display: block;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
    }
  }

  .input-dark {
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    padding: 1rem;
    border-radius: 12px;
    font-size: 1.1rem;
    outline: none;
    transition: border-color 0.3s;

    &:focus {
      border-color: var(--accent-gold);
    }
  }

  .btn-upload {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.1);
    padding: 1rem 2rem;
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.3s;
    color: white;
    font-weight: 500;
    border: 1px dashed rgba(255, 255, 255, 0.3);
    width: 100%;
    justify-content: center;

    &:hover {
      background: rgba(255, 255, 255, 0.15);
      border-color: var(--accent-gold);
    }

    margin-bottom: 0.5rem; // Space for reset button
    
    &.drop-active {
        background: rgba(255, 215, 0, 0.1);
        border-color: var(--accent-gold);
        transform: scale(1.02);
    }
  }

  .btn-reset {
    width: 100%;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: var(--text-muted);
    padding: 0.75rem;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s;
    margin-top: 0.5rem;
    
    &:hover {
        border-color: #ff4444;
        color: #ff4444;
    }
  }

  .generator-preview {
    flex: 1;
    display: flex;
    justify-content: center;
    perspective: 1000px;
  }

  .canvas-wrapper {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 3/4;
    background: #000;
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.1);
    position: relative;
    overflow: hidden;
    transform: rotateY(-5deg);
    transition: transform 0.3s;

    &:hover {
      transform: rotateY(0deg);
    }

    canvas {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
  }

  .btn-cinema-gold {
    width: 100%;
    margin-top: 1rem;
    &:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      filter: grayscale(1);
    }
  }
</style>

<script>
  function initGenerator() {
    const canvas = document.getElementById('card-canvas');
    if (!canvas) return; // Guard against missing element

    const ctx = canvas.getContext('2d');
    const nameInput = document.getElementById('actor-name');
    const roleInput = document.getElementById('actor-role');
    const photoInput = document.getElementById('actor-photo');
    const downloadBtn = document.getElementById('download-btn');

    let uploadedImage = null;

    // Load assets (Logo, Overlay, Texture)
    // For MVP we draw mostly code, but ideally load a png frame
    const logoImg = new Image();
    logoImg.src = '/logo.svg'; // Assuming standard logo exists or fallback text

    function drawCard() {
      // 1. Background
      ctx.fillStyle = '#111';
      ctx.fillRect(0, 0, 600, 800);

      // 2. Photo
      if (uploadedImage) {
        // Crop/Fit image logic
        const ratio = Math.max(600 / uploadedImage.width, 800 / uploadedImage.height);
        const centerShift_x = (600 - uploadedImage.width * ratio) / 2;
        const centerShift_y = (800 - uploadedImage.height * ratio) / 2;
        
        ctx.save();
        ctx.globalAlpha = 0.8; // Cinematic darkness
        ctx.filter = 'grayscale(20%) contrast(1.1)'; // Cinematic filter
        ctx.drawImage(uploadedImage, 0, 0, uploadedImage.width, uploadedImage.height,
                      centerShift_x, centerShift_y, uploadedImage.width * ratio, uploadedImage.height * ratio);
        ctx.restore();
      }

      // 3. Gradient Overlay (Bottom Up)
      const gradient = ctx.createLinearGradient(0, 400, 0, 800);
      gradient.addColorStop(0, 'transparent');
      gradient.addColorStop(0.7, 'rgba(10, 10, 15, 0.9)');
      gradient.addColorStop(1, '#000');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, 600, 800);

      // 4. "Noise" Texture (Optional code-based noise)
        // ... (skipping for performance)

      // 5. Borders / HUD
      ctx.strokeStyle = '#FFD700'; // Gold
      ctx.lineWidth = 4;
      ctx.strokeRect(20, 20, 560, 760);

      // Corner Accents
      ctx.fillStyle = '#FFD700';
      ctx.fillRect(20, 20, 40, 4); // Top Left H
      ctx.fillRect(20, 20, 4, 40); // Top Left V
      ctx.fillRect(540, 776, 40, 4); // Bot Right H
      ctx.fillRect(576, 740, 4, 40); // Bot Right V

      // 6. Text Content
      const name = nameInput.value.trim() || 'ИМЯ АКТЁРА';
      const role = roleInput.value;

      // Role
      ctx.font = '700 24px "Inter", sans-serif';
      ctx.fillStyle = '#FFD700';
      ctx.letterSpacing = '4px';
      ctx.textAlign = 'center';
      ctx.fillText(role, 300, 680);

      // Name
      ctx.font = '700 48px "Inter", sans-serif'; // Fallback font
      ctx.fillStyle = '#fff';
      ctx.letterSpacing = '0px';
      ctx.fillText(name.toUpperCase(), 300, 740);

      // Logo / Brand
      ctx.font = '16px sans-serif';
      ctx.fillStyle = 'rgba(255,255,255,0.5)';
      ctx.fillText('ТЕАТР «ЭМОЦИКА» | OFFICIAL CARD', 300, 780);
    }

    // Initial Draw
    drawCard();

    // Event Listeners
    nameInput.addEventListener('input', drawCard);
    roleInput.addEventListener('change', drawCard);

 
    
    // Drag and Drop
    const uploadLabel = document.querySelector('.btn-upload');
    
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        uploadLabel.addEventListener(eventName, preventDefaults, false);
    });

    function preventDefaults(e) {
        e.preventDefault();
        e.stopPropagation();
    }

    ['dragenter', 'dragover'].forEach(eventName => {
        uploadLabel.addEventListener(eventName, highlight, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
        uploadLabel.addEventListener(eventName, unhighlight, false);
    });

    function highlight(e) {
        uploadLabel.classList.add('drop-active');
    }

    function unhighlight(e) {
        uploadLabel.classList.remove('drop-active');
    }

    uploadLabel.addEventListener('drop', handleDrop, false);

    function handleDrop(e) {
        const dt = e.dataTransfer;
        const files = dt.files;
        handleFiles(files);
    }

    function handleFiles(files) {
        const file = files[0];
        if (file && file.type.startsWith('image/')) {
            const reader = new FileReader();
            reader.onload = (event) => {
                const img = new Image();
                img.onload = () => {
                    uploadedImage = img;
                    drawCard();
                    downloadBtn.disabled = false;
                    resetBtn.style.display = 'block';
                };
                img.src = event.target.result;
            };
            reader.readAsDataURL(file);
        }
    }
    
    // Reset Logic
    const resetBtn = document.getElementById('reset-btn');
    resetBtn.addEventListener('click', () => {
        nameInput.value = '';
        roleInput.value = 'АКТЁР';
        uploadedImage = null;
        photoInput.value = ''; // Clear file input
        downloadBtn.disabled = true;
        resetBtn.style.display = 'none';
        drawCard();
    });
    
    photoInput.addEventListener('change', (e) => {
      handleFiles(e.target.files);
    });

    downloadBtn.addEventListener('click', () => {
        const link = document.createElement('a');
        link.download = `emozika-card-${Date.now()}.png`;
        link.href = canvas.toDataURL();
        link.click();
    });
  }

  // Run on load
  document.addEventListener('astro:page-load', initGenerator);
  // Fallback for non-view-transitions
  if (!window.initGeneratorRun) {
      initGenerator();
      window.initGeneratorRun = true;
  }
</script>
