---
import awardsData from '../../data/vk_awards.json';

interface Props {
  limit?: number;
}

const { limit } = Astro.props;
const displayItems = limit ? awardsData.slice(0, limit) : awardsData;
---

<div class="awards-wall">
    <div class="wall-grid">
    {displayItems.map((award, index) => (
        <article class="diploma-frame" style={`--delay: ${index * 0.1}s`}>
            <div class="frame-wood">
                <div class="frame-matte">
                    <div class="frame-content">
                        {award.image ? (
                            <img src={award.image} alt={award.sublabel} class="diploma-img" loading="lazy" />
                        ) : (
                            <div class="diploma-placeholder">
                                <span class="cup">🏆</span>
                            </div>
                        )}
                        <div class="glass-reflection"></div>
                    </div>
                </div>
            </div>
            
            <div class="award-content">
                <div class="gold-plate">
                    <h3 class="plate-title">{award.label}</h3>
                    <div class="plate-divider"></div>
                    <p class="plate-subtitle">{award.sublabel}</p>
                    <div class="plate-screw screw-tl"></div>
                    <div class="plate-screw screw-tr"></div>
                    <div class="plate-screw screw-bl"></div>
                    <div class="plate-screw screw-br"></div>
                </div>
            </div>
        </article>
    ))}
    </div>
</div>

<style lang="scss">
    .awards-wall {
        padding: 4rem 0;
        background: 
            linear-gradient(rgba(255,255,255,0.95), rgba(255,255,255,0.95)),
            url("https://www.transparenttextures.com/patterns/white-wall-3.png");
    }

    .wall-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 4rem; /* Increased gap for plates */
        justify-content: center;
        max-width: 1200px;
        margin: 0 auto;
    }

    .diploma-frame {
        max-width: 320px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        opacity: 0;
        animation: hangOnWall 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        animation-delay: var(--delay);
        transform-origin: top center;
        
        &:hover {
            z-index: 10;
            .frame-wood {
                transform: scale(1.02) translateY(-5px);
                box-shadow: 0 25px 50px rgba(0,0,0,0.25);
            }
        }
    }

    .frame-wood {
        background: #3e2723;
        padding: 15px;
        border-radius: 4px;
        box-shadow: 
            0 15px 35px rgba(0,0,0,0.2),
            inset 0 0 0 2px rgba(255,255,255,0.05),
            inset 0 0 20px rgba(0,0,0,0.5);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        width: 100%;
    }

    .frame-matte {
        background: #fdfdfd;
        padding: 24px;
        box-shadow: inset 0 2px 8px rgba(0,0,0,0.1);
        border: 1px solid #e0e0e0;
    }

    .frame-content {
        position: relative;
        width: 100%;
        aspect-ratio: 1/1.414;
        overflow: hidden;
        border: 1px solid #eee;
    }

    .diploma-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .diploma-placeholder {
        width: 100%;
        height: 100%;
        background: #f4f1ea;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: #d4af37;
        background-image: radial-gradient(#d4af37 1px, transparent 1px);
        background-size: 20px 20px;
        opacity: 0.5;
    }

    .glass-reflection {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, transparent 40%, rgba(255,255,255,0.05) 100%);
        pointer-events: none;
    }

    /* Gold Plate Styles */
    .award-content {
        margin-top: 2rem;
        width: 100%;
        padding: 0 10px;
        position: relative;
    }

    .gold-plate {
        background: linear-gradient(to bottom, #f3e5ab 0%, #d4af37 50%, #c5a028 51%, #e6c86e 100%);
        padding: 12px 16px;
        border-radius: 4px;
        box-shadow: 
            0 4px 10px rgba(0,0,0,0.2),
            inset 0 1px 0 rgba(255,255,255,0.6),
            inset 0 -1px 0 rgba(0,0,0,0.2);
        border: 1px solid #b8860b;
        text-align: center;
        position: relative;
    }

    .plate-title {
        font-family: var(--font-heading, serif);
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #4a3728;
        letter-spacing: 0.05em;
        text-shadow: 0 1px 0 rgba(255,255,255,0.4);
        margin-bottom: 4px;
        line-height: 1.2;
    }

    .plate-divider {
        height: 1px;
        background: rgba(74, 55, 40, 0.3);
        width: 60%;
        margin: 4px auto;
        border-bottom: 1px solid rgba(255,255,255,0.3);
    }

    .plate-subtitle {
        font-size: 0.7rem;
        font-weight: 600;
        color: #5d4037;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        text-shadow: 0 1px 0 rgba(255,255,255,0.4);
    }

    .plate-screw {
        width: 4px;
        height: 4px;
        background: #3e2723;
        border-radius: 50%;
        position: absolute;
        box-shadow: 0 1px 0 rgba(255,255,255,0.5);
        
        &.screw-tl { top: 4px; left: 4px; }
        &.screw-tr { top: 4px; right: 4px; }
        &.screw-bl { bottom: 4px; left: 4px; }
        &.screw-br { bottom: 4px; right: 4px; }
    }

    @keyframes hangOnWall {
        from { 
            opacity: 0; 
            transform: translateY(-50px) rotate(5deg); 
        }
        to { 
            opacity: 1; 
            transform: translateY(0) rotate(0); 
        }
    }
</style>
