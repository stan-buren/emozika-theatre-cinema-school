---
import abonementsData from '../../data/abonements.json';

const tickets = (abonementsData || []).filter(item => !item.draft);
---

<section id="abonements" class="section section-tickets">
    <div class="container">
        <header class="section-header text-center mb-16">
            <span class="eyebrow">Для будущих талантов</span>
            <h2 class="section-title">Билетная Касса</h2>
            <p class="section-subtitle">Выберите свой формат обучения.</p>
        </header>

        <div class="tickets-grid">
            {tickets.map((ticket, index) => {
                const isPopular = ticket.badge === "Хит" || index === 1;
                return (
                <div class={`ticket-card ${isPopular ? 'ticket-card--popular' : ''}`}>
                    {isPopular && <div class="popular-tag">Выбор мам</div>}
                    <div class="ticket-content">
                        <header class="ticket-header">
                            <h3 class="ticket-title">{ticket.name}</h3>
                            <p class="ticket-age">{ticket.age}</p>
                        </header>
                        
                        <div class="ticket-price-wrapper">
                            <span class="ticket-price">{ticket.price}</span>
                            <span class="ticket-period">/ месяц</span>
                        </div>

                        <ul class="ticket-features">
                            {ticket.bullets && ticket.bullets.map(bullet => (
                                <li>
                                    <span class="check-icon">✓</span>
                                    <span class="feature-text">{bullet}</span>
                                </li>
                            ))}
                        </ul>

                        <button class="btn-ticket" data-open-modal="main-booking-modal">
                            Занять место
                        </button>
                    </div>
                </div>
            )})}
        </div>
        
         <div class="tickets-note mt-12 text-center">
            <p class="text-sm text-muted">* В стоимость уже включены костюмы, фотосессии и работа гримеров. Никаких скрытых сборов.</p>
        </div>
    </div>
</section>

<style lang="scss">
    /* Theme: "Hall of Fame" / Awards-like (Deep Purple & Gold) */
    .section-tickets {
        background: radial-gradient(circle at center top, #1a0b2e 0%, #0d041c 60%, #000000 100%);
        color: #fff;
        padding: 6rem 0;
        position: relative;
        overflow: hidden;
    }

    .eyebrow {
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        color: #D4AF37; /* Gold */
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        text-shadow: 0 0 10px rgba(212, 175, 55, 0.4);
    }

    .section-title {
        color: #D4AF37 !important;
        font-size: 3.5rem;
        margin-bottom: 1rem;
        text-shadow: 0 0 20px rgba(212, 175, 55, 0.2);
    }

    .section-subtitle {
        color: rgba(255, 255, 255, 0.8) !important;
        font-size: 1.1rem;
    }

    .tickets-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2.5rem;
        max-width: 1200px;
        margin: 0 auto;
        align-items: center;
        padding: 2rem 0;
    }

    .ticket-card {
        background: rgba(26, 11, 46, 0.6); /* Transparent Deep Purple */
        border: 1px solid rgba(212, 175, 55, 0.3); /* Gold border */
        border-radius: 4px; /* Plaque-like sharp corners with slight radius */
        padding: 3rem 2rem;
        box-shadow: 
            0 10px 30px rgba(0,0,0,0.5),
            inset 0 0 20px rgba(0,0,0,0.5); /* Inner shadow for depth */
        position: relative;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
        display: flex;
        flex-direction: column;
        height: 100%;

        /* Art Deco / Plaque Corners */
        clip-path: polygon(
            0% 0%, 
            100% 0%, 
            100% calc(100% - 15px), 
            calc(100% - 15px) 100%, 
            0% 100%
        );

        &:hover {
            transform: translateY(-10px);
            background: rgba(40, 20, 70, 0.8);
            border-color: #D4AF37;
            box-shadow: 0 20px 50px rgba(0,0,0,0.7), 0 0 15px rgba(212, 175, 55, 0.2);
        }

        &--popular {
            border: 2px solid #D4AF37;
            background: rgba(40, 20, 70, 0.7);
            transform: scale(1.05);
            z-index: 10;
            box-shadow: 0 20px 60px rgba(0,0,0,0.6), 0 0 20px rgba(212, 175, 55, 0.3);

            &:hover {
                transform: scale(1.05) translateY(-5px);
            }
        }
    }

    .popular-tag {
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        background: linear-gradient(135deg, #BF953F 0%, #FCF6BA 50%, #B38728 100%); /* Gold Gradient */
        color: #1a0b2e;
        padding: 0.5rem 1.5rem;
        border-radius: 2px;
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        box-shadow: 0 5px 15px rgba(0,0,0,0.5);
        border: 1px solid #fff;
    }

    .ticket-header {
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(212, 175, 55, 0.2);
    }

    .ticket-title {
        font-family: var(--font-heading, serif);
        font-size: 1.8rem;
        font-weight: 400;
        color: #fff;
        margin-bottom: 0.25rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    }

    .ticket-age {
        font-size: 0.9rem;
        text-transform: uppercase;
        color: #D4AF37; /* Gold */
        letter-spacing: 0.15em;
        font-weight: 600;
        background: transparent;
        padding: 0;
    }

    .ticket-price-wrapper {
        text-align: center;
        margin-bottom: 2rem;
    }

    .ticket-price {
        font-size: 3rem;
        font-weight: 400;
        color: #fff;
        display: block;
        line-height: 1;
        font-family: var(--font-heading, serif);
        text-shadow: 0 0 15px rgba(255,255,255,0.4);
    }

    .ticket-period {
        font-size: 0.9rem;
        color: rgba(255,255,255,0.6);
        text-transform: uppercase;
        margin-top: 0.5rem;
        display: block;
        letter-spacing: 0.05em;
    }

    .ticket-features {
        list-style: none;
        padding: 0;
        margin: 0 0 2.5rem;
        flex-grow: 1;

        li {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 1rem;
            font-size: 1rem;
            line-height: 1.5;
            color: rgba(255,255,255,0.9);
            padding-left: 1rem;
            border-left: 1px solid #D4AF37; /* Gold accent line */

            .check-icon {
                display: none;
            }
        }
    }

    .btn-ticket {
        width: 100%;
        padding: 1.2rem;
        background: transparent;
        color: #D4AF37;
        border: 1px solid #D4AF37;
        border-radius: 4px;
        font-weight: 600;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-family: var(--font-heading, serif);

        &:hover {
            background: #D4AF37;
            color: #1a0b2e;
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.5);
        }

        .ticket-card--popular & {
            background: #D4AF37;
            color: #1a0b2e;
            border: none;
            font-weight: 800;

            &:hover {
                background: #fff;
                color: #000;
                box-shadow: 0 0 30px rgba(255, 255, 255, 0.4);
            }
        }
    }
</style>
