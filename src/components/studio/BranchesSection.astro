---
import BranchesInteractiveGrid from './BranchesInteractiveGrid.astro';
import LeafletMap from '../common/LeafletMap.astro';
import branchesData from '../../data/branches.json';

const branches = branchesData.branches || [];
const sortedBranches = [...branches].sort((a, b) => {
    // 1. Сначала площадки с группами 18+
    if (a.isAdults && !b.isAdults) return -1;
    if (!a.isAdults && b.isAdults) return 1;

    // 2. Потом по станции метро (по алфавиту)
    var metroA = (a.metro || "").toLowerCase();
    var metroB = (b.metro || "").toLowerCase();
    if (metroA < metroB) return -1;
    if (metroA > metroB) return 1;

    // 3. Город (на всякий случай)
    var cityA = (a.city || "").toLowerCase();
    var cityB = (b.city || "").toLowerCase();
    if (cityA < cityB) return -1;
    if (cityA > cityB) return 1;

    // 4. Название площадки
    var placeA = (a.place || "").toLowerCase();
    var placeB = (b.place || "").toLowerCase();
    if (placeA < placeB) return -1;
    if (placeA > placeB) return 1;

    return 0;
});
---

<section id="branches" class="section section-branches reveal-on-scroll">
  <div class="container">
    
    <div class="branches-layout-grid">
        
        <!-- Top Section: Controls & Map -->
        <div class="branches-top-section">
            <div class="branches-content-col">
                <header class="branches-header">
                    <p class="section-kicker">Где проходят занятия</p>
                    <h2 class="section-title">Филиалы и площадки</h2>
                </header>

                <div class="branches-smart-search">
                    <div class="search-row">
                        <button class="btn-geo" id="btn-geo" aria-label="Найти рядом со мной">
                            📍 Рядом
                        </button>
                        <div class="search-input-wrapper">
                            <input type="text" id="branch-search" placeholder="Метро или адрес..." class="search-input" />
                            <span class="search-icon">🔍</span>
                        </div>
                    </div>
                    
                    <div class="filter-chips">
                        <button type="button" class="filter-chip is-active" data-branch-filter="all">Все</button>
                        <button type="button" class="filter-chip" data-branch-filter="kids">Дети</button>
                        <button type="button" class="filter-chip" data-branch-filter="adults">Взрослые</button>
                        <button type="button" class="filter-chip" data-branch-filter="cinema">Киношкола</button>
                    </div>
                </div>
            </div>

            <!-- Map Side -->
            <div class="branches-map-col" data-aos="fade-left">
                <div class="sticky-map-wrapper">
                        <LeafletMap branches={branches} />
                </div>
            </div>
        </div>

        <!-- Full Width Grid Below -->
        <div class="branches-list-wrapper">
            <BranchesInteractiveGrid branches={sortedBranches} />
            
            <p class="branches-note">
                Полный список филиалов уточняйте у администратора.
                <a href="/about#contacts" class="branches-note-link">Контакты →</a>
            </p>
        </div>
    </div>

    <!-- Hidden select for fallback -->
    <select class="visually-hidden" data-branch-my-metro>
            <option value="">Не выбрано</option>
            {(() => {
            const uniqueMetros = [...new Set(sortedBranches.map(b => b.metro).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'ru'));
            return uniqueMetros.map(metro => (
                <option value={metro}>{metro}</option>
            ));
            })()}
    </select>

  </div>
</section>

<script>
    // Smart Branch Logic
    function initSmartBranches() {
        const geoBtn = document.getElementById('btn-geo');
        const searchInput = document.getElementById('branch-search') as HTMLInputElement;
        const cards = document.querySelectorAll('.branch-interactive-card');
        const grid = document.querySelector('.branch-cards-grid');

        // 1. Geolocation
        geoBtn?.addEventListener('click', () => {
            if (!navigator.geolocation) {
                alert('Ваш браузер не поддерживает геолокацию');
                return;
            }
            
            geoBtn.classList.add('loading');
            geoBtn.textContent = '...';

            navigator.geolocation.getCurrentPosition(
                (position) => {
                    const { latitude, longitude } = position.coords;
                    sortByDistance(latitude, longitude);
                    
                    // Dispatch event for Map component
                    document.dispatchEvent(new CustomEvent('map-geo-location', { 
                        detail: { lat: latitude, lon: longitude } 
                    }));

                    geoBtn.textContent = '📍 Рядом';
                    geoBtn.classList.remove('loading');
                    geoBtn.classList.add('active');
                },
                (error) => {
                    console.error(error);
                    alert('Не удалось определить местоположение.');
                    geoBtn.textContent = '📍 Рядом';
                    geoBtn.classList.remove('loading');
                }
            );
        });

        // 2. Search
        searchInput?.addEventListener('input', (e) => {
            const term = (e.target as HTMLInputElement).value.toLowerCase();
            let hasVisible = false;

            cards.forEach(card => {
                const text = (card.textContent || "").toLowerCase();
                const isMatch = text.includes(term);
                (card as HTMLElement).style.display = isMatch ? 'flex' : 'none';
                if(isMatch) hasVisible = true;
            });
        });

        // 3. Distance Sorter (Haversine)
        function sortByDistance(lat: number, lon: number) {
            const cardsArray = Array.from(cards) as HTMLElement[];
            
            cardsArray.sort((a, b) => {
                const coordsA = JSON.parse(a.dataset.coords || "[0,0]");
                const coordsB = JSON.parse(b.dataset.coords || "[0,0]");
                
                const distA = getDistanceFromLatLonInKm(lat, lon, coordsA[0], coordsA[1]);
                const distB = getDistanceFromLatLonInKm(lat, lon, coordsB[0], coordsB[1]);
                
                updateDistanceBadge(a, distA);
                updateDistanceBadge(b, distB);

                return distA - distB;
            });

            cardsArray.forEach(card => grid?.appendChild(card));
        }

        function updateDistanceBadge(card: HTMLElement, dist: number) {
            let badge = card.querySelector('.distance-badge');
            if (!badge) {
                badge = document.createElement('div');
                badge.className = 'distance-badge';
                card.querySelector('.card-visual')?.appendChild(badge);
            }
            badge.textContent = `${dist.toFixed(1)} км`;
        }

        function getDistanceFromLatLonInKm(lat1: number, lon1: number, lat2: number, lon2: number) {
            var R = 6371; 
            var dLat = deg2rad(lat2-lat1);  
            var dLon = deg2rad(lon2-lon1); 
            var a = 
                Math.sin(dLat/2) * Math.sin(dLat/2) +
                Math.cos(deg2rad(lat1)) * Math.cos(deg2rad(lat2)) * 
                Math.sin(dLon/2) * Math.sin(dLon/2); 
            var c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a)); 
            var d = R * c; 
            return d;
        }

        function deg2rad(deg: number) {
            return deg * (Math.PI/180)
        }
        
        // Filter Chips Logic
        document.querySelectorAll('.filter-chip').forEach(btn => {
            btn.addEventListener('click', (e) => {
               document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('is-active'));
               const target = e.target as HTMLElement;
               target.classList.add('is-active');
               
               const filter = target.dataset.branchFilter;
               
               cards.forEach(card => {
                   const isAdult = card.dataset.adults !== undefined;
                   const isCinema = card.dataset.cinema !== undefined; 
                   
                   if (filter === 'all') {
                       (card as HTMLElement).style.display = 'flex';
                   } else if (filter === 'adults') {
                       (card as HTMLElement).style.display = isAdult ? 'flex' : 'none';
                   } else if (filter === 'kids') {
                       (card as HTMLElement).style.display = !isAdult ? 'flex' : 'none';
                   } else if (filter === 'cinema') {
                       (card as HTMLElement).style.display = isCinema ? 'flex' : 'none';
                   }
               });
            });
        });

        // 5. Teacher Selection Listener
        document.addEventListener('find-teacher-branches', (e) => {
            const { branchIds, teacherName } = (e as CustomEvent).detail;
            
            // Scroll to section start
            const section = document.getElementById('branches');
            section?.scrollIntoView({ behavior: 'smooth' });

            // Filter Cards
            let count = 0;
            cards.forEach(card => {
                const cardId = (card as HTMLElement).dataset.branchId;
                const match = branchIds && branchIds.includes(cardId);
                
                if(match) {
                    (card as HTMLElement).style.display = 'flex';
                    (card as HTMLElement).classList.add('highlight-pulse');
                    count++;
                } else {
                    (card as HTMLElement).style.display = 'none';
                    (card as HTMLElement).classList.remove('highlight-pulse');
                }
            });

            if(searchInput) {
                 searchInput.value = `📍 Педагог: ${teacherName}`;
            }
            
            document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('is-active'));
        });
    }

    initSmartBranches();
    document.addEventListener('astro:after-swap', initSmartBranches);
</script>

<style lang="scss">
    /* Refactored Layout: Top Map/Controls -> Bottom Grid */
    .branches-layout-grid {
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }

    /* Top Section: Sidebar-like controls + Map */
    .branches-top-section {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;

        @media (min-width: 900px) {
            grid-template-columns: 400px 1fr; /* Controls Left, Map Right */
            align-items: stretch;
        }
    }

    .branches-content-col {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        /* Now just the header/search area */
    }

    .branches-map-col {
        min-height: 400px;
        border-radius: 20px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        
        @media (min-width: 900px) {
            height: auto; /* Match height of controls or min */
            min-height: 450px;
        }
    }

    .sticky-map-wrapper {
        width: 100%;
        height: 100%;
        min-height: 400px;
    }

    /* Full Width Grid matches "occupy whole page" */
    .branches-list-wrapper {
        width: 100%;
    }
    
    .branches-note {
        text-align: center;
        max-width: 600px;
        margin: 2rem auto 0;
    }



    .branches-smart-search {
        display: grid;
        gap: 1rem;
        background: #fff;
        padding: 1.5rem;
        border-radius: 16px;
        border: 1px solid #eee;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }

    .search-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        align-items: center;
    }

    .btn-geo {
        background: white;
        border: 2px solid #f0f0f0;
        padding: 0 1.2rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s;
        height: 48px;
        white-space: nowrap;
        
        &:hover { border-color: #ddd; }
        &.active { background: #d4af37; border-color: #d4af37; color: white; }
    }

    .section-title {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: 2.5rem;
        margin-bottom: 2rem;
        color: #1a0b2e;
    }

    .search-input-wrapper {
        position: relative;
        flex: 1;
        min-width: 200px;
    }

    .search-input {
        width: 100%;
        height: 48px;
        padding: 0 1rem;
        padding-right: 2.5rem;
        border: 2px solid #f0f0f0;
        border-radius: 12px;
        font-size: 0.95rem;
        transition: all 0.3s;
        
        &:focus {
            outline: none;
            border-color: #d4af37;
            background: white;
            box-shadow: 0 4px 12px rgba(212, 175, 55, 0.1);
        }
    }

    .search-icon {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        opacity: 0.4;
    }

    .filter-chips {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .filter-chip {
        background: #f5f5f5;
        border: 1px solid transparent;
        padding: 0.5rem 1rem;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        color: #666;
        
        &:hover { background: #eee; color: #333; }
        &.is-active {
            background: #2d2d2d;
            color: white;
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        }
    }
    
    .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0,0,0,0);
        white-space: nowrap;
        border: 0;
    }

    .branches-note {
        font-size: 0.9rem;
        color: #888;
        margin-top: 1rem;
    }

    .branches-note-link {
        color: #d4af37;
        text-decoration: none;
        font-weight: 500;
        margin-left: 0.3rem;
        &:hover { text-decoration: underline; }
    }
</style>
