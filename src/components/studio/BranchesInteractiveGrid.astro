---
interface Props {
  branches: any[];
}

const { branches } = Astro.props;

function getGradient(color: string) {
    const map: Record<string, string> = {
        purple: "linear-gradient(135deg, #7a2fb4 0%, #4a1f6b 100%)",
        blue: "linear-gradient(135deg, #40E0D0 0%, #20B2AA 100%)",
        orange: "linear-gradient(135deg, #FFD700 0%, #FFA500 100%)",
        green: "linear-gradient(135deg, #90EE90 0%, #32CD32 100%)",
        cyan: "linear-gradient(135deg, #E0FFFF 0%, #00FFFF 100%)",
        red: "linear-gradient(135deg, #FF6347 0%, #FF4500 100%)"
    };
    return map[color] || map.purple;
}
---

<div class="branch-cards-grid">
    {branches.map(branch => {
        const isAdults = branch.isAdults; 
        const link = branch.mapLink || "#yandex-map";
        const gradient = getGradient(branch.photoUrl);
        
        return (
            <article 
                class="branch-interactive-card" 
                data-metro={(branch.metro || "").toLowerCase()} 
                data-adults={isAdults ? "" : undefined}
                data-cinema={branch.isCinema ? "" : undefined}
                data-branch-id={branch.id}
                data-coords={JSON.stringify(branch.coords || [0,0])}
                tabindex="0"
            >
                <div class="card-visual" style={`background: ${gradient}`}>
                    <span class="visual-icon">🏛️</span>
                    {isAdults && <span class="badge-18">18+</span>}
                </div>
                
                <div class="card-content">
                    <div class="card-header">
                        <h3 class="card-title">{branch.place}</h3>
                        <div class="card-metro-row">
                             <span class="metro-dot"></span>
                             <span class="card-metro">{branch.metro || "Метро"}</span>
                        </div>
                    </div>
                    
                    <p class="card-address">{branch.address}</p>
                    
                    <div class="card-footer">
                        <a href={link} class="card-link" target="_blank">
                            Показать на карте →
                        </a>
                    </div>
                </div>
            </article>
        );
    })}
</div>

<style lang="scss">
    .branch-cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
        padding-top: 2rem;
    }

    .branch-interactive-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        position: relative;
        height: 100%;

        &:hover, &:focus {
            transform: translateY(-8px);
            box-shadow: 0 20px 50px rgba(48, 16, 74, 0.15); /* Purple shadow */
            z-index: 2;
        }
    }

    .card-visual {
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%);
    }

    .visual-icon {
        font-size: 3rem;
        opacity: 0.2;
        mix-blend-mode: overlay;
        transform: rotate(-10deg);
    }

    .badge-18 {
        position: absolute;
        top: 10px;
        right: 10px;
        background: #000;
        color: #d4af37; /* Gold text */
        font-size: 0.75rem;
        font-weight: 800;
        padding: 4px 8px;
        border-radius: 4px;
        border: 1px solid #d4af37;
    }

    .card-content {
        padding: 1.5rem 1.5rem 2rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        background: linear-gradient(to bottom, #fff 50%, #fafafa 100%);
    }

    .card-header {
        margin-bottom: 1rem;
    }

    .card-title {
        font-family: var(--font-heading, serif);
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        line-height: 1.2;
        color: #1a0b2e; /* Deep purple */
    }

    .card-metro-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .metro-dot {
        width: 10px;
        height: 10px;
        background: #D70100;
        border-radius: 50%;
        box-shadow: 0 0 0 2px rgba(215, 1, 0, 0.2);
    }

    .card-metro {
        font-size: 0.95rem;
        color: #555;
        font-weight: 600;
        letter-spacing: 0.02em;
    }

    .card-address {
        font-size: 0.9rem;
        color: #777;
        margin-bottom: 1.5rem;
        line-height: 1.5;
        border-top: 1px dashed rgba(0,0,0,0.1);
        padding-top: 1rem;
    }

    .card-footer {
        margin-top: auto;
    }

    .card-link {
        font-size: 0.85rem;
        font-weight: 700;
        color: #7a2fb4; /* Brand purple */
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: gap 0.2s;
        
        &:hover {
            gap: 8px;
            color: #4a1f6b;
        }
    }

    /* Highlight Animation */
    :global(.highlight-pulse) {
        animation: pulseHighlight 0.8s ease;
        border-color: #d4af37 !important;
        box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.2), 0 15px 40px rgba(0,0,0,0.2) !important;
        transform: scale(1.02);
        z-index: 5;
    }

    @keyframes pulseHighlight {
        0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(212, 175, 55, 0.4); }
        50% { transform: scale(1.03); box-shadow: 0 0 0 10px rgba(212, 175, 55, 0); }
        100% { transform: scale(1.02); }
    }
</style>
